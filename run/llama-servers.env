# ==============================
# Global runtime configuration
# ==============================

HOST=127.0.0.1
THREADS=0
BATCH_SIZE=512

# Default context if not overridden
CTX_SIZE=8192
GPU_LAYERS=0

# ==============================
# Ports
# ==============================

PERSONA_PORT=8080
SCIENTIST_PORT=8081

# ==============================
# Models (do NOT rename files)
# ==============================

PERSONA_MODEL=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
SCIENTIST_MODEL=Qwen2.5-14B-Instruct-Q5_K_M.gguf

# ==============================
# Context sizes
# ==============================

PERSONA_CTX=8192
SCIENTIST_CTX=12288

# ==============================
# GPU offload tuning
# (96GB EVO-X2 can handle this)
# ==============================

GPU_LAYERS_PERSONA=35
GPU_LAYERS_SCIENTIST=45

